# Shopify
SHOPIFY_STORE=turn-offroad.myshopify.com
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=your_client_secret
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_LOCATION_RIVERSIDE=gid://shopify/Location/xxxxx
SHOPIFY_LOCATION_TOR_PRODUCTION=gid://shopify/Location/yyyyy

# Email (Resend)
RESEND_API_KEY=re_xxx
FROM_EMAIL=feeds@turnoffroad.com
ALERT_EMAIL=sunil@cloveode.com

# Recipients are managed via the dashboard at APP_URL (stored in data/feed.sqlite)

# Feed settings
EMAIL_SUBJECT=Turn Offroad Daily Inventory Feed
CRON_SCHEDULE=0 6 * * *
TIMEZONE=America/New_York

# Server
PORT=3002
APP_URL=https://inventoryfeed-turnoffroad.duckdns.org
